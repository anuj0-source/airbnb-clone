<button type="button"
    class="absolute top-3 right-3 z-10 save-heart p-2 rounded-full backdrop-blur shadow-sm transition
    <%= home.favourite 
        ? 'bg-red-100 hover:bg-red-200' 
        : 'bg-white/80 hover:scale-110 hover:bg-white' %>"
    data-id="<%= home.id %>"
    data-fav="<%= home.favourite %>"
    onclick="event.preventDefault(); event.stopPropagation(); saveToWishlist(this);">

    <!-- SVG -->
    <svg 
        class="w-5 h-5 transition 
        <%= home.favourite ? 'text-red-500' : 'text-gray-600' %>" 
        fill="<%= home.favourite ? 'currentColor' : 'none' %>" 
        stroke="currentColor" 
        stroke-width="2" 
        viewBox="0 0 24 24">

        <path stroke-linecap="round" stroke-linejoin="round"
            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
    </svg>

</button>
