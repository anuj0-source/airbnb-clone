<!-- Wishlist Toast Notification -->
<div id="wishlist-toast" 
     class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[100]
            flex items-center gap-3 px-5 py-3.5 
            bg-gray-900 text-white rounded-xl shadow-2xl
            transition-all duration-300 ease-out
            translate-y-20 opacity-0 pointer-events-none">
  

  <!-- Message -->
  <span id="toast-message" class="text-sm font-medium">Saved to wishlist</span>

  <!-- View Link -->
  <a href="/wishlists" class="text-sm font-semibold text-[#FF5A5F] hover:underline ml-2 whitespace-nowrap">
    View list
  </a>

  <!-- Close Button -->
  <button onclick="hideToast()" class="ml-1 p-1 hover:bg-white/10 rounded-full transition">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
</div>

<script>
  let toastTimeout;

  function showToast(message) {
    const toast = document.getElementById('wishlist-toast');
    const msgEl = document.getElementById('toast-message');
    if (message) msgEl.textContent = message;
    
    // Show
    toast.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
    toast.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');

    // Auto-hide after 3s
    clearTimeout(toastTimeout);
    toastTimeout = setTimeout(hideToast, 3000);
  }

  function hideToast() {
    const toast = document.getElementById('wishlist-toast');
    toast.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
    toast.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
  }
</script>
