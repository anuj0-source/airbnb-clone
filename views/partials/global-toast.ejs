<!-- Global Toast Notification -->
<% if (typeof toastMsg !== 'undefined' && toastMsg) { %>
<div id="globalToast" class="global-toast show">
  <div class="global-toast-icon">
    <% if (typeof toastType !== 'undefined' && toastType === 'error') { %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
    <% } else { %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
    <% } %>
  </div>
  <span class="global-toast-msg"><%= toastMsg %></span>
  <button class="global-toast-close" onclick="closeGlobalToast()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
</div>
<% } %>

<style>
  .global-toast {
    position: fixed;
    bottom: -80px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    background: #222;
    color: #fff;
    border-radius: 14px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.18);
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 14px;
    font-weight: 500;
    transition: bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    max-width: 90vw;
    white-space: nowrap;
  }

  .global-toast.show {
    bottom: 32px;
  }

  .global-toast.hiding {
    bottom: -80px;
  }

  .global-toast-icon svg {
    width: 20px;
    height: 20px;
    stroke: #34D399;
    flex-shrink: 0;
  }

  .global-toast.error .global-toast-icon svg {
    stroke: #FF385C;
  }

  .global-toast-msg {
    letter-spacing: 0.1px;
  }

  .global-toast-close {
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.15s;
    margin-left: 4px;
    flex-shrink: 0;
  }

  .global-toast-close:hover {
    background: rgba(255,255,255,0.15);
  }

  .global-toast-close svg {
    width: 16px;
    height: 16px;
    stroke: #aaa;
  }

  @media (max-width: 768px) {
    .global-toast {
      font-size: 13px;
      padding: 12px 16px;
      border-radius: 12px;
    }
    .global-toast.show {
      bottom: 80px;
    }
  }
</style>

<script>
  function closeGlobalToast() {
    const t = document.getElementById('globalToast');
    if (t) {
      t.classList.remove('show');
      t.classList.add('hiding');
    }
  }

  // Auto-dismiss after 3.5s
  (function() {
    const t = document.getElementById('globalToast');
    if (t) {
      setTimeout(closeGlobalToast, 3500);
    }
  })();
</script>
