<!-- Preload Inter Font -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<!-- Navbar Styles -->
<style>
  #navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(255,245,248,0.95));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,56,92,0.08);
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    font-family: 'Inter', sans-serif;
  }

  .nav-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .nav-logo img {
    height: 34px;
    width: auto;
    filter: drop-shadow(0 2px 4px rgba(255,56,92,0.2));
    transition: transform 0.3s ease;
  }

  .nav-logo:hover img {
    transform: scale(1.08) rotate(-3deg);
  }

  .nav-logo span {
    font-size: 22px;
    font-weight: 700;
    background: linear-gradient(135deg, #FF385C, #E31C5F);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.5px;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 4px;
    background: rgba(0,0,0,0.03);
    border-radius: 999px;
    position: relative;
  }

  .nav-slider {
    position: absolute;
    height: calc(100% - 8px);
    top: 4px;
    left: 4px;
    background: #FF385C;
    border-radius: 999px;
    box-shadow: 0 4px 15px rgba(255,56,92,0.35);
    z-index: 0;
    pointer-events: none;
  }

  .nav-link {
    display: block;
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    color: #666;
    transition: color 0.25s ease;
    position: relative;
    z-index: 1;
  }

  .nav-link:hover {
    color: #FF385C;
  }

  .nav-link.active {
    color: #fff;
  }

  .nav-cta {
    display: block;
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-left: 4px;
  }

  .nav-cta.inactive {
    color: #FF385C;
    background: rgba(255,56,92,0.08);
    border: 1.5px solid rgba(255,56,92,0.3);
  }

  .nav-cta.inactive:hover {
    background: #FF385C;
    color: #fff;
    border-color: #FF385C;
    box-shadow: 0 4px 15px rgba(255,56,92,0.35);
    transform: translateY(-1px);
  }

  .nav-cta.active {
    background: linear-gradient(135deg, #FF385C, #E31C5F);
    color: #fff;
    border: 1.5px solid transparent;
    box-shadow: 0 4px 15px rgba(255,56,92,0.35);
  }

  #menuBtn {
    display: none;
    background: none;
    border: 1.5px solid #eee;
    border-radius: 12px;
    padding: 8px;
    font-size: 20px;
    color: #555;
    cursor: pointer;
    transition: all 0.2s;
  }

  #menuBtn:hover {
    border-color: #FF385C;
    color: #FF385C;
    background: rgba(255,56,92,0.04);
  }

  .nav-login-btn {
    display: inline-flex;
    align-items: center;
    padding: 9px 22px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: #FF385C;
    background: transparent;
    border: 1.5px solid #FF385C;
    transition: all 0.25s ease;
    letter-spacing: 0.2px;
    margin-left: 12px;
  }

  .nav-login-btn:hover {
    transform: translateY(-1px);
    color: #fff;
    background: linear-gradient(135deg, #FF385C, #E31C5F);
    border-color: transparent;
    box-shadow: 0 6px 20px rgba(255,56,92,0.4);
  }

  .nav-login-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(255,56,92,0.3);
  }

  .nav-login-btn.active {
    color: #fff;
    background: linear-gradient(135deg, #FF385C, #E31C5F);
    border-color: transparent;
    box-shadow: 0 4px 15px rgba(255,56,92,0.3);
  }

  .nav-login-mobile-li {
    display: none;
  }

  @media (max-width: 768px) {
    .nav-container {
      padding: 12px 20px;
      position: relative;
    }
    .nav-logo span {
      font-size: 18px;
    }
    .nav-logo img {
      height: 28px;
    }
    #menuBtn {
      display: flex !important;
      align-items: center;
      justify-content: center;
      order: 3;
    }
    .nav-menu {
      display: none !important;
      flex-direction: column;
      position: absolute;
      top: calc(100% + 8px);
      left: 16px;
      right: 16px;
      width: auto;
      background: #fff;
      padding: 16px;
      gap: 6px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.12);
      border-radius: 20px;
      border: 1px solid rgba(0,0,0,0.06);
      z-index: 100;
    }
    .nav-menu.show { display: flex !important; }
    .nav-slider { display: none !important; }
    .nav-link {
      text-align: center;
      padding: 14px 20px;
      border-radius: 14px;
      color: #333;
      font-size: 15px;
    }
    .nav-link:hover {
      background: rgba(255,56,92,0.06);
    }
    .nav-link.active {
      background: linear-gradient(135deg, #FF385C, #E31C5F);
      color: #fff;
    }
    .nav-cta {
      text-align: center;
      margin-left: 0;
      margin-top: 4px;
      padding: 14px 20px;
      border-radius: 14px;
      font-size: 15px;
    }
    .nav-login-btn {
      display: none;
    }
    .nav-login-mobile-li {
      display: block;
    }
    .nav-login-mobile {
      display: block;
      width: 100%;
      text-align: center;
      padding: 14px 20px;
      border-radius: 14px;
      font-size: 15px;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      text-decoration: none;
      color: #fff;
      background: linear-gradient(135deg, #FF385C, #E31C5F);
      border: none;
      margin-top: 6px;
      cursor: pointer;
    }
    .nav-login-mobile:hover {
      box-shadow: 0 4px 15px rgba(255,56,92,0.35);
    }
    .nav-login-mobile.active {
      box-shadow: 0 4px 15px rgba(255,56,92,0.35);
    }
  }
</style>

<nav id="navbar">
  <div class="nav-container">

    <!-- Logo -->
    <a href="/" class="nav-logo">
      <img src="/airbnb.png" alt="logo">
      <span>airbnb</span>
    </a>

    <!-- Hamburger -->
    <button id="menuBtn">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <!-- Menu -->
    <ul class="nav-menu" id="menu">
      <div class="nav-slider" id="navSlider"></div>
      <li><a href="/" class="nav-link <%= url === '/' ? 'active' : ''%>">Home</a></li>

      <% if(isLoggedIn == true){ %>
      <li><a href="/bookings" class="nav-link <%= url === '/bookings' ? 'active' : '' %>">Bookings</a></li>
      <li><a href="/wishlists" class="nav-link <%= url === '/wishlists' ? 'active' : '' %>">Wishlists</a></li>
      <li><a href="/host/listings" class="nav-link <%= url === '/host/listings' ? 'active' : '' %>">Listings</a></li>
      <li><a href="/host/add-home" class="nav-cta <%= url === '/host/add-home' ? 'active' : 'inactive' %>">+ Add Property</a></li>
      <% } %>
      <li class="nav-login-mobile-li">
        <% if(isLoggedIn) { %>
          <form method="POST" action="/logout" style="margin:0;">
            <button type="submit" class="nav-login-mobile">Logout</button>
          </form>
        <% } else { %>
          <a href="/login" class="nav-login-mobile <%= url === '/login' ? 'active' : '' %>">Login</a>
        <% } %>
      </li>
    </ul>

    <!-- Login Button -->
    <form method=<%= isLoggedIn? 'POST' : 'GET' %> action=<%= isLoggedIn? '/logout' : '/login' %>>
    <button type="submit" class="nav-login-btn <%= url === '/login' ? 'active' : '' %>"><%= isLoggedIn? 'Logout' : 'Login' %></button>
    </form>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById("menuBtn");
  const menu = document.getElementById("menu");
  menuBtn.addEventListener("click", () => menu.classList.toggle("show"));

  const navLogo=document.querySelector(".nav-logo");

  navLogo.addEventListener('click',(event)=>{
    const currPath=window.location.href;

    if(currPath == 'http://localhost:3000/'){
        event.preventDefault();
    }

  });

  // Sliding pill indicator
  (function initSlider() {
    const slider = document.getElementById('navSlider');
    const activeLink = document.querySelector('.nav-link.active');
    const menuEl = document.getElementById('menu');
    if (!slider || !menuEl) return;

    function getPos(link) {
      const mRect = menuEl.getBoundingClientRect();
      const lRect = link.getBoundingClientRect();
      return {
        width: lRect.width,
        height: lRect.height,
        left: lRect.left - mRect.left,
        top: lRect.top - mRect.top
      };
    }

    function setPos(pos, animate) {
      if (!animate) slider.style.transition = 'none';
      else slider.style.transition = 'all 0.35s cubic-bezier(0.4, 0, 0.2, 1)';
      slider.style.width = pos.width + 'px';
      slider.style.height = pos.height + 'px';
      slider.style.left = pos.left + 'px';
      slider.style.top = pos.top + 'px';
      slider.style.opacity = '1';
    }

    // On load: place slider instantly on the active link
    if (activeLink) {
      setPos(getPos(activeLink), false);
    } else {
      slider.style.opacity = '0';
    }

    // On click: animate slider to clicked link, THEN navigate
    document.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const href = this.getAttribute('href');
        if (this.classList.contains('active')) {
          return;
        }

        const clickedLink = this;

        // Fade old active link text back to gray
        if (activeLink) {
          activeLink.style.transition = 'color 0.35s cubic-bezier(0.4, 0, 0.2, 1)';
          activeLink.style.color = '#666';
        }

        // Fade clicked link text to white (in sync with pill)
        clickedLink.style.transition = 'color 0.35s cubic-bezier(0.4, 0, 0.2, 1)';
        clickedLink.style.color = '#fff';

        // Slide pill to clicked link
        slider.offsetHeight;
        setPos(getPos(clickedLink), true);

        // Navigate after the slide animation finishes
        setTimeout(() => { window.location.href = href; }, 380);
      });
    });

    // Recalculate on resize
    window.addEventListener('resize', () => {
      if (activeLink) setPos(getPos(activeLink), false);
    });
  })();
</script>