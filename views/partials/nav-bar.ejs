                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
                <span class="tab-text">Trips</span>
              </a>
            </li>
            <% } %>
              <% } %>
    </ul>

    <!-- Right Section -->
    <div class="nav-right">
      <% if (isLoggedIn) { %>
        <% if(userType=='host' ) {%>
          <form action="/change-user/<%= userId %>" method="POST">
            <button class="nav-host-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <path d="M2 12h20" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
              <span>Switch to travelling</span>
            </button>
          </form>
          <% } else { %>
            <form action="/change-user/<%= userId %>" method="POST">
              <button type="submit" class="nav-host-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round"
                  stroke-linejoin="round">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                  <path d="M9 22V12h6v10" />
                  <path d="M14.5 6.5l-2-2-2 2" />
                  <line x1="12.5" y1="4.5" x2="12.5" y2="9" />
                </svg>
                <span>Switch to hosting</span>
              </button>
            </form>
            <% } %>
              <% } %>

                <!-- Profile Area -->
                <div class="profile-area">
                  <% if (isLoggedIn) { %>
                    <a href="/profile/<%= userId %>" class="nav-avatar" title="My Profile">
                      <svg viewBox="0 0 24 24" fill="currentColor">
                        <path
                          d="M12 12c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm0 2c-3.33 0-10 1.67-10 5v2h20v-2c0-3.33-6.67-5-10-5z" />
                      </svg>
                    </a>
                    <% } %>
                      <button class="menu-btn" id="profileBtn" aria-label="User menu">
                        <div class="bar-group">
                          <span></span><span></span><span></span>
                        </div>
                      </button>

                      <div class="profile-dropdown" id="profileDropdown">
                        <% if (isLoggedIn) { %>
                          <% if(userType=='host' ) {%>
                            <a href="/host/add-home" class="dropdown-item">Add property</a>
                            <a href="/host/listings" class="dropdown-item">Manage listings</a>
                            <% } %>
                              <div class="dropdown-divider"></div>
                              <form method="POST" action="/logout" style="margin:0;">
                                <button type="submit" class="dropdown-item">Log out</button>
                              </form>
                              <% } else { %>
                                <a href="/login" class="dropdown-item bold">Log in</a>
                                <a href="/signup" class="dropdown-item">Sign up</a>
                                <div class="dropdown-divider"></div>
                                <a href="/host/add-home" class="dropdown-item">Airbnb your home</a>
                                <% } %>
                      </div>
                </div>
    </div>

  </div>
</nav>

