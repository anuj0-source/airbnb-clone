<script>
  // === Profile dropdown toggle ===
  const profileBtn = document.getElementById('profileBtn');
  const profileDropdown = document.getElementById('profileDropdown');

  profileBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    profileDropdown.classList.toggle('show');
  });

  document.addEventListener('click', (e) => {
    if (!profileDropdown.contains(e.target) && !profileBtn.contains(e.target)) {
      profileDropdown.classList.remove('show');
    }
  });

  // === Navbar shadow on scroll ===
  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 2);
  }, { passive: true });

  // === Prevent reload on active page ===
  document.querySelector('.nav-logo').addEventListener('click', (e) => {
    if (window.location.pathname === '/') e.preventDefault();
  });

  document.querySelectorAll('.nav-tab-link').forEach(link => {
    link.addEventListener('click', function (e) {
      if (this.classList.contains('active')) e.preventDefault();
    });
  });

  // === Mobile slide-up menu ===
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileSlideMenu = document.getElementById('mobileSlideMenu');
  const mobileMenuOverlay = document.getElementById('mobileMenuOverlay');

  function openMobileMenu() {
    mobileMenuOverlay.classList.add('show');
    // Small delay so CSS transition triggers
    requestAnimationFrame(() => {
      mobileSlideMenu.classList.add('show');
    });
    mobileMenuBtn.classList.add('active');
  }

  function closeMobileMenu() {
    mobileSlideMenu.classList.remove('show');
    mobileMenuOverlay.classList.remove('show');
    mobileMenuBtn.classList.remove('active');
  }

  mobileMenuBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (mobileSlideMenu.classList.contains('show')) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  });

  mobileMenuOverlay.addEventListener('click', closeMobileMenu);
</script>

