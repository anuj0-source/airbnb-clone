<div id="navbar"
     class="sticky top-0 z-50 px-6 py-4 flex justify-between items-center 
            bg-[#FF5A5F]/90 backdrop-blur-md transition-all duration-300">

    <!-- Logo -->
    <a href="/">
        <h1 class="text-white font-bold text-xl">Airbnb</h1>
    </a>

    <!-- Hamburger (mobile only) -->
    <button id="menuBtn" class="md:hidden text-white text-2xl">
        ☰
    </button>

    <!-- Menu -->
    <ul id="menu"
        class="absolute md:static top-full left-0 w-full md:w-auto 
               bg-[#FF5A5F] md:bg-transparent
               flex-col md:flex-row flex gap-6
               p-6 md:p-0 hidden md:flex">

        <!-- Home -->
        <li class="relative group">
            <a href="/" class="inline-block px-4 py-2 text-white">Home</a>
            <span class="absolute left-0 bottom-0 h-[2px] bg-white transition-all duration-300
                <%= url === '/' ? 'w-full' : 'w-0 group-hover:w-full' %>"></span>
        </li>

        <!-- Bookings -->
        <li class="relative group">
            <a href="/bookings" class="inline-block px-4 py-2 text-white">Bookings</a>
            <span class="absolute left-0 bottom-0 h-[2px] bg-white transition-all duration-300
                <%= url === '/bookings' ? 'w-full' : 'w-0 group-hover:w-full' %>"></span>
        </li>

        <!-- Wishlist -->
        <li class="relative group">
            <a href="/wishlists" class="inline-block px-4 py-2 text-white">Wishlists</a>
            <span class="absolute left-0 bottom-0 h-[2px] bg-white transition-all duration-300
                <%= url === '/wishlists' ? 'w-full' : 'w-0 group-hover:w-full' %>"></span>
        </li>

        <!-- Listings -->
        <li class="relative group">
            <a href="/host/listings" class="inline-block px-4 py-2 text-white">Listings</a>
            <span class="absolute left-0 bottom-0 h-[2px] bg-white transition-all duration-300
                <%= url === '/host/listings' ? 'w-full' : 'w-0 group-hover:w-full' %>"></span>
        </li>

        <!-- Add Property -->
        <li class="relative group">
            <a href="/host/add-home" class="inline-block px-4 py-2 text-white">
                Add Property
            </a>
            <span class="absolute left-0 bottom-0 h-[2px] bg-white transition-all duration-300
                <%= url === '/host/add-home' ? 'w-full' : 'w-0 group-hover:w-full' %>"></span>
        </li>
    </ul>
</div>

<!-- JS for toggle -->
<script>
    const menuBtn = document.getElementById("menuBtn");
    const menu = document.getElementById("menu");

    menuBtn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
    });
</script>