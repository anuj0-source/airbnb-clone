<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/output.css">
    <title>Your Listings – Airbnb</title>
    <style>
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .fade-up {
            opacity: 0;
            animation: fadeUp 0.5s ease-out forwards;
        }
        .fade-up-1 { animation-delay: 0.05s; }
        .fade-up-2 { animation-delay: 0.15s; }
        .fade-up-3 { animation-delay: 0.25s; }
    </style>
</head>

<body class="bg-gray-50 min-h-screen flex flex-col">

    <%- include('../partials/nav-bar') %>

    <!-- Page Header -->
    <div class="max-w-6xl mx-auto w-full px-6 sm:px-10 pt-10 pb-6 fade-up fade-up-1">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-[32px] font-bold text-gray-900">Your listings</h1>
                <p class="text-gray-500 mt-1">Manage your properties and track performance</p>
            </div>
            <a href="/host/add-home"
               class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg
                      bg-[#FF5A5F] text-white text-sm font-semibold
                      hover:bg-[#e04848] transition active:scale-95 shadow-md">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Add listing
            </a>
        </div>
    </div>

    <!-- Tabs -->
    <div class="max-w-6xl mx-auto w-full px-6 sm:px-10 fade-up fade-up-2">
        <div class="flex gap-8 border-b border-gray-200">
            <button class="pb-3 text-sm font-semibold text-gray-900 border-b-2 border-gray-900">
                All (<%= homes.length %>)
            </button>
            <button class="pb-3 text-sm font-medium text-gray-400 hover:text-gray-600 transition">
                Active
            </button>
            <button class="pb-3 text-sm font-medium text-gray-400 hover:text-gray-600 transition">
                Inactive
            </button>
        </div>
    </div>

    <% if (homes && homes.length > 0) { %>
    <!-- Listings Grid -->
    <div class="max-w-6xl mx-auto w-full px-6 sm:px-10 py-8 fade-up fade-up-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% homes.forEach((home, index) => { %>
            <div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition duration-300 border border-gray-200 group"
                 style="animation-delay: <%= index * 0.08 %>s">

                <!-- Image -->
                <div class="h-48 overflow-hidden relative">
                    <img src="<%= home.image %>"
                         alt="<%= home.houseName %>"
                         class="w-full h-full object-cover transition duration-300 group-hover:scale-105"/>
                </div>

                <!-- Content -->
                <div class="p-5">
                    <div class="flex justify-between items-start">
                        <div class="flex-1 min-w-0">
                            <h3 class="text-gray-900 font-semibold text-lg truncate"><%= home.houseName %></h3>
                            <p class="text-gray-500 text-sm mt-1"><%= home.location %></p>
                        </div>
                        <span class="ml-3 text-xs font-medium px-2.5 py-1 rounded-full
                            bg-green-50 text-green-700 border border-green-200 whitespace-nowrap">
                            Active
                        </span>
                    </div>

                    <p class="text-gray-400 text-sm mt-2 line-clamp-2"><%= home.description %></p>

                    <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
                        <p class="text-gray-900 font-bold text-lg">
                            ₹<%= home.price %>
                            <span class="text-gray-400 font-normal text-sm">/ night</span>
                        </p>
                        <div class="flex items-center gap-2 text-sm text-gray-500">
                            <span><%= home.size %> guests</span>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex gap-3 mt-4">
                        <a href="/host/edit-home/<%= home.id %>"
                           class="flex-1 text-center px-4 py-2 rounded-lg text-sm font-medium
                                  border border-gray-300 text-gray-700
                                  hover:bg-gray-50 transition active:scale-95">
                            Edit
                        </a>
                        <button type="button"
                                data-action="/host/delete/<%= home.id %>?_method=DELETE"
                                data-name="<%= home.houseName %>"
                                onclick="openDeleteModal(this.dataset.action, this.dataset.name)"
                                class="flex-1 px-4 py-2 rounded-lg text-sm font-medium
                                       border border-red-200 text-red-600
                                       hover:bg-red-50 transition active:scale-95">
                            Delete
                        </button>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
    <% } else { %>
    <!-- Empty State -->
    <div class="flex-1 flex items-center justify-center px-6 fade-up fade-up-3">
        <div class="text-center py-20 max-w-md">

            <!-- Illustration -->
            <div class="w-40 h-40 mx-auto mb-8 relative">
                <div class="absolute inset-0 bg-gradient-to-br from-[#FF5A5F]/10 to-[#FC642D]/5 rounded-full"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="w-20 h-20 text-[#FF5A5F]/50" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
                    </svg>
                </div>
            </div>

            <h2 class="text-2xl font-bold text-gray-900 mb-2">No listings yet</h2>
            <p class="text-gray-500 leading-relaxed mb-8">
                You haven't added any properties yet. List your first space and start earning on Airbnb.
            </p>

            <a href="/host/add-home"
               class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl
                      bg-gradient-to-r from-[#FF5A5F] to-[#FC642D] text-white font-semibold
                      shadow-lg shadow-red-200 hover:shadow-xl hover:shadow-red-300
                      hover:from-[#e04848] hover:to-[#e55a28] transition-all duration-200 active:scale-95">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Create your first listing
            </a>

            <!-- Helper text -->
            <div class="mt-12 border-t border-gray-200 pt-8">
                <p class="text-sm text-gray-400">
                    Need help getting started?
                    <a href="#" class="text-[#FF5A5F] font-medium hover:underline ml-1">Learn about hosting</a>
                </p>
            </div>
        </div>
    </div>
    <% } %>
    <footer class="border-t border-gray-200 bg-white mt-auto">
        <div class="max-w-6xl mx-auto px-6 sm:px-10 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
            <p class="text-sm text-gray-400">&copy; 2026 Airbnb, Inc. &middot; Privacy &middot; Terms &middot; Sitemap</p>
            <div class="flex items-center gap-4 text-sm text-gray-500">
                <span>🌐 English (IN)</span>
                <span>₹ INR</span>
            </div>
        </div>
    </footer>

    <!-- Delete Confirmation Modal -->
    <div id="delete-modal" class="fixed inset-0 z-50 hidden">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity duration-300 opacity-0"
             id="delete-backdrop" onclick="closeDeleteModal()"></div>

        <!-- Modal Card -->
        <div class="absolute inset-0 flex items-center justify-center p-4">
            <div id="delete-card"
                 class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6
                        transform scale-95 opacity-0 transition-all duration-300">

                <!-- Icon -->
                <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-red-50 flex items-center justify-center">
                    <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                    </svg>
                </div>

                <!-- Title -->
                <h3 class="text-lg font-bold text-gray-900 text-center">Delete listing</h3>

                <!-- Description -->
                <p class="text-sm text-gray-500 text-center mt-2 leading-relaxed">
                    Are you sure you want to delete
                    <span id="delete-home-name" class="font-semibold text-gray-700"></span>?
                    This action cannot be undone.
                </p>

                <!-- Buttons -->
                <div class="flex gap-3 mt-6">
                    <button onclick="closeDeleteModal()"
                            class="flex-1 px-4 py-2.5 rounded-xl text-sm font-semibold
                                   border border-gray-300 text-gray-700
                                   hover:bg-gray-50 transition active:scale-95">
                        Cancel
                    </button>
                    <form id="delete-form" method="POST" class="flex-1">
                        <button type="submit"
                                class="w-full px-4 py-2.5 rounded-xl text-sm font-semibold
                                       bg-red-500 text-white
                                       hover:bg-red-600 transition active:scale-95
                                       shadow-lg shadow-red-200">
                            Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openDeleteModal(action, name) {
            const modal = document.getElementById('delete-modal');
            const backdrop = document.getElementById('delete-backdrop');
            const card = document.getElementById('delete-card');
            const form = document.getElementById('delete-form');
            const nameEl = document.getElementById('delete-home-name');

            form.action = action;
            nameEl.textContent = name;

            modal.classList.remove('hidden');
            // Trigger animation on next frame
            requestAnimationFrame(() => {
                backdrop.classList.remove('opacity-0');
                backdrop.classList.add('opacity-100');
                card.classList.remove('scale-95', 'opacity-0');
                card.classList.add('scale-100', 'opacity-100');
            });
        }

        function closeDeleteModal() {
            const modal = document.getElementById('delete-modal');
            const backdrop = document.getElementById('delete-backdrop');
            const card = document.getElementById('delete-card');

            backdrop.classList.remove('opacity-100');
            backdrop.classList.add('opacity-0');
            card.classList.remove('scale-100', 'opacity-100');
            card.classList.add('scale-95', 'opacity-0');

            setTimeout(() => modal.classList.add('hidden'), 300);
        }

        // Close on Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeDeleteModal();
        });
    </script>

    <%- include('../partials/nav-script') %>

    <%- include('../partials/wishlist-toast') %>

    <script>
        (function() {
            const params = new URLSearchParams(window.location.search);
            const toast = params.get('toast');
            if (toast && typeof showToast === 'function') {
                showToast(decodeURIComponent(toast));
                // Clean URL without reload
                window.history.replaceState({}, '', window.location.pathname);
            }
        })();
    </script>

</body>

</html>
