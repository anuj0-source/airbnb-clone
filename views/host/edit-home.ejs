<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Add Home</title>
  <link rel="stylesheet" href="/output.css">
</head>

<body class="bg-gray-100">

  <!-- Navbar -->
   <%- include("../partials/nav-bar") %>

  <!-- Form Container -->
  <div class="max-w-xl mx-auto mt-10 bg-white p-8 rounded-2xl shadow-lg">

    <h2 class="text-2xl font-bold mb-6 text-center">
    <%= edit ? "Edit" : "Add" %> Your Property
    </h2>

    <form method="POST" action="<%= edit? `/host/edit-home/${home.id}` : '/host/add-home' %>" class="space-y-5">

      <!-- House Name -->
      <div>
        <label class="block text-gray-700 font-medium mb-1">House Name</label>
        <input type="text" name="house-name"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400"
          placeholder="Enter your house name" value="<%= edit ? home.houseName : '' %>" required>
      </div>

      <!-- Size -->
      <div>
        <label class="block text-gray-700 font-medium mb-1">Size (BHK)</label>
        <input type="text" name="size"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400"
          placeholder="e.g. 2 BHK" value="<%= edit? home.size : '' %>" required>
      </div>

      <!-- Location -->
      <div>
        <label class="block text-gray-700 font-medium mb-1">Location</label>
        <input type="text" name="location"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400"
          placeholder="Enter location" value="<%= edit? home.location : '' %>">
      </div>

      <!-- Price -->
      <div>
        <label class="block text-gray-700 font-medium mb-1">Price (₹/night)</label>
        <input type="number" name="price"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400"
          placeholder="Enter price" value="<%= edit? home.price : '' %>">
      </div>

      <!-- image url -->
      <div class="mb-4">
        <label class="block text-gray-700 mb-2">Upload Image</label>
        <input type="url" name="image" class="w-full border border-gray-300 p-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400" placeholder="Enter image URL" value="<%= edit? home.image : '' %>"> 
      </div>

      <!-- Description -->
      <div>
        <label class="block text-gray-700 font-medium mb-1">Enter description</label>
        <input type="text" name="description"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400"
          placeholder="Enter description" value="<%= edit? home.description : '' %>">
      </div>


      <!-- Submit Button -->
      <button class="relative h-12 overflow-hidden rounded bg-[#FF5A5F] px-5 py-2.5 text-white transition-all duration-300 hover:bg-[#e04848] hover:ring-2 hover:ring-red-900 hover:ring-offset-2"><span class="relative"><%= edit? "Update" : "Add" %> home</span></button>

    </form>
  </div>

</body>

</html>