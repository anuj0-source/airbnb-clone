<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/favicon') %>
  <title>Add Home</title>
  <link rel="stylesheet" href="/output.css">
</head>


<body class="bg-gradient-to-tr from-[#FFFAF0] via-[#FFF5F5] to-[#F0F4FF] min-h-screen">
  <%- include("../partials/nav-bar") %>

  <div class="max-w-2xl mx-auto mt-12 bg-white/90 p-10 rounded-3xl shadow-2xl border border-gray-200">
    <div class="flex flex-col items-center mb-8">
      <div class="mb-2">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="24" cy="24" r="23" stroke="#FF5A5F" stroke-width="2" fill="#FFF" />
          <path d="M24 12v24M12 24h24" stroke="#FF5A5F" stroke-width="2" stroke-linecap="round" />
        </svg>
      </div>
      <h2 class="text-3xl font-extrabold text-[#FF5A5F] tracking-tight mb-1">
        <%= edit ? "Edit" : "Add" %> Your Property
      </h2>
      <p class="text-gray-500 text-lg">Showcase your space to millions of guests</p>
    </div>

    <% if (edit && home.imageUrl) { %>
      <div class="mb-6 flex justify-center">
        <img src="<%= home.imageUrl %>" alt="Property image" class="rounded-xl shadow-lg w-72 h-48 object-cover border border-gray-200">
      </div>
    <% } %>

    <form method="POST" action="<%= edit? `/host/edit-home/${home._id}` : `/host/add-home/${userId}` %>" class="space-y-6">
      <div>
        <label class="block text-gray-700 font-semibold mb-2">House Name</label>
        <input type="text" name="house-name" class="w-full bg-gray-50 border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#FF5A5F] text-lg" placeholder="Enter your house name" value="<%= edit ? home.houseName : '' %>" required>
      </div>
      <div>
        <label class="block text-gray-700 font-semibold mb-2">Size (BHK)</label>
        <input type="text" name="size" class="w-full bg-gray-50 border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#FF5A5F] text-lg" placeholder="e.g. 2 BHK" value="<%= edit? home.size : '' %>" required>
      </div>
      <div>
        <label class="block text-gray-700 font-semibold mb-2">Location</label>
        <input type="text" name="location" class="w-full bg-gray-50 border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#FF5A5F] text-lg" placeholder="Enter location" value="<%= edit? home.location : '' %>">
      </div>
      <div>
        <label class="block text-gray-700 font-semibold mb-2">Price (₹/night)</label>
        <input type="number" name="price" class="w-full bg-gray-50 border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#FF5A5F] text-lg" placeholder="Enter price" value="<%= edit? home.price : '' %>">
      </div>
      <div>
        <label class="block text-gray-700 font-semibold mb-2">Image URL</label>
        <input type="url" name="image" class="w-full bg-gray-50 border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#FF5A5F] text-lg" placeholder="Enter image URL" value="<%= edit? home.imageUrl : '' %>">
      </div>
      <div>
        <label class="block text-gray-700 font-semibold mb-2">Description</label>
        <textarea name="description" rows="3" class="w-full bg-gray-50 border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#FF5A5F] text-lg" placeholder="Enter description"><%= edit? home.homeDescription : '' %></textarea>
      </div>
      <button class="w-full h-12 rounded-xl bg-[#FF5A5F] text-white text-lg font-bold shadow-lg transition-all duration-300 hover:bg-[#e04848] hover:scale-105 focus:ring-2 focus:ring-[#FF5A5F] focus:ring-offset-2">
        <%= edit? "Update" : "Add" %> home
      </button>
    </form>
    <div class="mt-8 text-center text-gray-400 text-sm">
      <span>Need help? <a href="https://www.airbnb.com/help" class="text-[#FF5A5F] underline">See hosting tips</a></span>
    </div>
  </div>
</body>
</html>