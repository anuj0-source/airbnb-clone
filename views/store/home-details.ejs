<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= home ? home.houseName : 'Not Found' %> – Airbnb</title>
    <link rel="stylesheet" href="/output.css">
    <style>
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .fade-up { opacity: 0; animation: fadeUp 0.5s ease-out forwards; }
        .fd1 { animation-delay: 0.05s; }
        .fd2 { animation-delay: 0.12s; }
        .fd3 { animation-delay: 0.2s; }
        .fd4 { animation-delay: 0.28s; }
        .fd5 { animation-delay: 0.36s; }
    </style>
</head>

<body class="bg-white min-h-screen flex flex-col">

    <%- include("../partials/nav-bar") %>

    <% if(home) { %>

    <!-- Main Container -->
    <div class="max-w-6xl mx-auto w-full px-6 sm:px-10 pt-8 pb-12 flex-1">

        <!-- Title Section -->
        <div class="fade-up fd1">
            <h1 class="text-[26px] font-semibold text-gray-900"><%= home.houseName %></h1>
            <div class="flex items-center gap-3 mt-1 text-sm text-gray-600">
                <span class="flex items-center gap-1 font-medium">⭐ 4.92</span>
                <span class="text-gray-300">·</span>
                <span class="underline font-medium">128 reviews</span>
                <span class="text-gray-300">·</span>
                <span class="underline font-medium"><%= home.location %></span>
            </div>
        </div>

        <!-- Hero Image -->
        <div class="mt-6 rounded-2xl overflow-hidden fade-up fd2">
            <div class="relative">
                <img src="<%= home.imageUrl %>"
                     alt="<%= home.houseName %>"
                     class="w-full h-[60vh] object-cover"/>
                <!-- Share & Save buttons -->
                <div class="absolute top-4 right-4 flex gap-2">
                    <%- include("../partials/save-btn",{home:home}) %>
                </div>
            </div>
        </div>

        <!-- Content Grid -->
        <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-12">

            <!-- Left Column (Details) -->
            <div class="lg:col-span-2">

                <!-- Host Info -->
                <div class="fade-up fd3 flex items-center justify-between pb-6 border-b border-gray-200">
                    <div>
                        <h2 class="text-[22px] font-semibold text-gray-900">
                            Entire home in <%= home.location %>
                        </h2>
                        <p class="text-gray-500 mt-1">
                            <%= home.size %> BHK · 2 guests · 1 bedroom · 1 bed · 1 bath
                        </p>
                    </div>
                    <div class="w-12 h-12 rounded-full bg-gray-800 flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
                        H
                    </div>
                </div>

                <!-- Highlights -->
                <div class="fade-up fd3 py-6 border-b border-gray-200 space-y-5">
                    <div class="flex gap-4">
                        <svg class="w-6 h-6 text-gray-700 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
                        </svg>
                        <div>
                            <p class="font-medium text-gray-900">Entire home</p>
                            <p class="text-gray-500 text-sm">You'll have the entire place to yourself.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <svg class="w-6 h-6 text-gray-700 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                        </svg>
                        <div>
                            <p class="font-medium text-gray-900">Sparkling clean</p>
                            <p class="text-gray-500 text-sm">Recent guests said this place was sparkling clean.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <svg class="w-6 h-6 text-gray-700 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                        </svg>
                        <div>
                            <p class="font-medium text-gray-900">Great location</p>
                            <p class="text-gray-500 text-sm">95% of recent guests gave the location a 5-star rating.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <svg class="w-6 h-6 text-gray-700 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
                        </svg>
                        <div>
                            <p class="font-medium text-gray-900">Free cancellation before check-in</p>
                            <p class="text-gray-500 text-sm">Get a full refund if you change your mind.</p>
                        </div>
                    </div>
                </div>

                <!-- Description -->
                <div class="fade-up fd4 py-6 border-b border-gray-200">
                    <p class="text-gray-700 leading-relaxed">
                        <%= home.homeDescription %>
                    </p>
                </div>

                <!-- Amenities -->
                <div class="fade-up fd4 py-6 border-b border-gray-200">
                    <h3 class="text-[22px] font-semibold text-gray-900 mb-5">What this place offers</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex items-center gap-4 text-gray-700">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0"/>
                            </svg>
                            <span>Wifi</span>
                        </div>
                        <div class="flex items-center gap-4 text-gray-700">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
                            </svg>
                            <span>Kitchen</span>
                        </div>
                        <div class="flex items-center gap-4 text-gray-700">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
                            </svg>
                            <span>Free parking</span>
                        </div>
                        <div class="flex items-center gap-4 text-gray-700">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.875c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125z"/>
                            </svg>
                            <span>TV</span>
                        </div>
                        <div class="flex items-center gap-4 text-gray-700">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
                            </svg>
                            <span>Air conditioning</span>
                        </div>
                        <div class="flex items-center gap-4 text-gray-700">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/>
                            </svg>
                            <span>Heating</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Right Column (Booking Card) -->
            <div class="lg:col-span-1 fade-up fd3">
                <div class="sticky top-24 bg-white rounded-xl border border-gray-200 shadow-xl p-6">

                    <!-- Price -->
                    <div class="flex items-baseline gap-1 mb-6">
                        <span class="text-[22px] font-semibold text-gray-900">₹<%= home.price %></span>
                        <span class="text-gray-500">night</span>
                    </div>

                    <!-- Date Inputs -->
                    <div class="border border-gray-300 rounded-xl overflow-hidden mb-4">
                        <div class="grid grid-cols-2">
                            <div class="p-3 border-r border-gray-300">
                                <label class="block text-[10px] font-bold uppercase tracking-wider text-gray-700">Check-in</label>
                                <input type="date" class="w-full text-sm text-gray-900 mt-0.5 outline-none bg-transparent"/>
                            </div>
                            <div class="p-3">
                                <label class="block text-[10px] font-bold uppercase tracking-wider text-gray-700">Checkout</label>
                                <input type="date" class="w-full text-sm text-gray-900 mt-0.5 outline-none bg-transparent"/>
                            </div>
                        </div>
                        <div class="p-3 border-t border-gray-300">
                            <label class="block text-[10px] font-bold uppercase tracking-wider text-gray-700">Guests</label>
                            <select class="w-full text-sm text-gray-900 mt-0.5 outline-none bg-transparent">
                                <option>1 guest</option>
                                <option>2 guests</option>
                                <option>3 guests</option>
                                <option>4 guests</option>
                            </select>
                        </div>
                    </div>

                    <!-- Reserve Button -->
                    <button class="w-full py-3 rounded-lg text-white font-semibold text-base
                                   bg-gradient-to-r from-[#FF5A5F] to-[#FC642D]
                                   shadow-lg shadow-red-200 hover:shadow-xl hover:shadow-red-300
                                   hover:from-[#e04848] hover:to-[#e55a28]
                                   transition-all duration-200 active:scale-95">
                        Reserve
                    </button>

                    <p class="text-center text-sm text-gray-500 mt-3">You won't be charged yet</p>

                    <!-- Price Breakdown -->
                    <div class="mt-5 pt-5 border-t border-gray-200 space-y-3 text-sm">
                        <div class="flex justify-between text-gray-700">
                            <span class="underline">₹<%= home.price %> x 5 nights</span>
                            <span>₹<%= home.price * 5 %></span>
                        </div>
                        <div class="flex justify-between text-gray-700">
                            <span class="underline">Cleaning fee</span>
                            <span>₹500</span>
                        </div>
                        <div class="flex justify-between text-gray-700">
                            <span class="underline">Airbnb service fee</span>
                            <span>₹1,200</span>
                        </div>
                    </div>

                    <div class="mt-4 pt-4 border-t border-gray-200 flex justify-between font-semibold text-gray-900">
                        <span>Total before taxes</span>
                        <span>₹<%= (home.price * 5) + 500 + 1200 %></span>
                    </div>

                </div>
            </div>

        </div>

        <!-- Reviews Section -->
        <div class="fade-up fd5 mt-8 pt-8 border-t border-gray-200">
            <div class="flex items-center gap-2 mb-6">
                <span class="text-[22px] font-semibold text-gray-900">⭐ 4.92</span>
                <span class="text-[22px] font-semibold text-gray-900">·</span>
                <span class="text-[22px] font-semibold text-gray-900">128 reviews</span>
            </div>

            <!-- Rating Bars -->
            <div class="grid grid-cols-2 gap-x-16 gap-y-3 mb-10 max-w-2xl">
                <div class="flex items-center gap-3">
                    <span class="text-sm text-gray-700 w-28">Cleanliness</span>
                    <div class="flex-1 h-1 bg-gray-200 rounded-full"><div class="h-1 bg-gray-900 rounded-full" style="width:96%"></div></div>
                    <span class="text-xs font-semibold text-gray-700">4.9</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-gray-700 w-28">Accuracy</span>
                    <div class="flex-1 h-1 bg-gray-200 rounded-full"><div class="h-1 bg-gray-900 rounded-full" style="width:98%"></div></div>
                    <span class="text-xs font-semibold text-gray-700">5.0</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-gray-700 w-28">Communication</span>
                    <div class="flex-1 h-1 bg-gray-200 rounded-full"><div class="h-1 bg-gray-900 rounded-full" style="width:96%"></div></div>
                    <span class="text-xs font-semibold text-gray-700">4.9</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-gray-700 w-28">Location</span>
                    <div class="flex-1 h-1 bg-gray-200 rounded-full"><div class="h-1 bg-gray-900 rounded-full" style="width:100%"></div></div>
                    <span class="text-xs font-semibold text-gray-700">5.0</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-gray-700 w-28">Check-in</span>
                    <div class="flex-1 h-1 bg-gray-200 rounded-full"><div class="h-1 bg-gray-900 rounded-full" style="width:100%"></div></div>
                    <span class="text-xs font-semibold text-gray-700">5.0</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-gray-700 w-28">Value</span>
                    <div class="flex-1 h-1 bg-gray-200 rounded-full"><div class="h-1 bg-gray-900 rounded-full" style="width:92%"></div></div>
                    <span class="text-xs font-semibold text-gray-700">4.8</span>
                </div>
            </div>

            <!-- Review Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-8">
                <div>
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-gray-700 flex items-center justify-center text-white font-bold text-sm">R</div>
                        <div>
                            <p class="font-semibold text-gray-900 text-sm">Rahul</p>
                            <p class="text-gray-500 text-xs">February 2026</p>
                        </div>
                    </div>
                    <p class="text-gray-700 text-sm leading-relaxed">
                        Amazing place! The views were breathtaking and the host was incredibly welcoming. Would definitely come back again.
                    </p>
                </div>
                <div>
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-[#FF5A5F] flex items-center justify-center text-white font-bold text-sm">P</div>
                        <div>
                            <p class="font-semibold text-gray-900 text-sm">Priya</p>
                            <p class="text-gray-500 text-xs">January 2026</p>
                        </div>
                    </div>
                    <p class="text-gray-700 text-sm leading-relaxed">
                        Very clean and cozy. Loved the location — close to everything. The kitchen was well-equipped and the bed was super comfortable.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <% } else { %>

    <!-- Not Found State -->
    <div class="flex-1 flex items-center justify-center px-6">
        <div class="text-center py-20">
            <div class="w-32 h-32 mx-auto mb-6 relative">
                <div class="absolute inset-0 bg-gradient-to-br from-red-100 to-red-50 rounded-full"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="w-16 h-16 text-[#FF5A5F]/50" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                    </svg>
                </div>
            </div>
            <h1 class="text-2xl font-bold text-gray-900 mb-2">Property not found</h1>
            <p class="text-gray-500 mb-6">This listing may have been removed or doesn't exist.</p>
            <a href="/" class="inline-block px-6 py-3 rounded-lg bg-[#FF5A5F] text-white font-semibold hover:bg-[#e04848] transition active:scale-95">
                Back to listings
            </a>
        </div>
    </div>

    <% } %>

    <!-- Footer -->
    <%- include("../partials/footer") %>

    <%- include('../partials/wishlist-toast') %>

    <%- include("../partials/save-script") %>

    <%- include("../partials/nav-script") %>

</body>
</html>