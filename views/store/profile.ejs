<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../partials/favicon') %>
        <title>
            <%= user.firstName %>'s Profile – Airbnb
        </title>
        <link rel="stylesheet" href="/output.css">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
            rel="stylesheet">

        <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                background: #F7F7F7;
                color: #222;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            /* ===== ANIMATIONS ===== */
            @keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(24px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                }

                to {
                    opacity: 1;
                }
            }

            @keyframes scaleIn {
                from {
                    opacity: 0;
                    transform: scale(0.92);
                }

                to {
                    opacity: 1;
                    transform: scale(1);
                }
            }

            @keyframes shimmer {
                0% {
                    background-position: -200% 0;
                }

                100% {
                    background-position: 200% 0;
                }
            }

            @keyframes float {

                0%,
                100% {
                    transform: translateY(0);
                }

                50% {
                    transform: translateY(-6px);
                }
            }

            .anim-fade-up {
                opacity: 0;
                animation: fadeUp 0.6s ease-out forwards;
            }

            .anim-scale-in {
                opacity: 0;
                animation: scaleIn 0.5s ease-out forwards;
            }

            .anim-fade-in {
                opacity: 0;
                animation: fadeIn 0.6s ease-out forwards;
            }

            /* ===== PROFILE LAYOUT ===== */
            .profile-page {
                max-width: 1120px;
                margin: 0 auto;
                padding: 40px 24px 80px;
                width: 100%;
            }

            .profile-grid {
                display: grid;
                grid-template-columns: 340px 1fr;
                gap: 48px;
                align-items: start;
            }

            /* ===== LEFT SIDEBAR - PROFILE CARD ===== */
            .profile-card {
                background: #fff;
                border-radius: 24px;
                border: 1px solid #EBEBEB;
                box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
                padding: 32px 28px;
                position: sticky;
                top: 100px;
                transition: box-shadow 0.3s ease;
            }

            .profile-card:hover {
                box-shadow: 0 6px 30px rgba(0, 0, 0, 0.08);
            }

            .profile-card-top {
                display: flex;
                flex-direction: column;
                align-items: center;
                text-align: center;
                padding-bottom: 24px;
                border-bottom: 1px solid #F0F0F0;
            }

            .avatar-wrapper {
                position: relative;
                width: 120px;
                height: 120px;
                margin-bottom: 16px;
            }

            .avatar-img {
                width: 120px;
                height: 120px;
                border-radius: 50%;
                object-fit: cover;
                border: 4px solid #fff;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
                transition: transform 0.3s ease, box-shadow 0.3s ease;
            }

            .avatar-img:hover {
                transform: scale(1.05);
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.16);
            }

            .superhost-badge {
                position: absolute;
                bottom: 2px;
                right: 2px;
                width: 32px;
                height: 32px;
                background: linear-gradient(135deg, #FF385C, #E61E4D);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 3px solid #fff;
                box-shadow: 0 2px 8px rgba(255, 56, 92, 0.3);
                animation: float 3s ease-in-out infinite;
            }

            .superhost-badge svg {
                width: 14px;
                height: 14px;
                color: #fff;
                fill: #fff;
            }

            .profile-name {
                font-size: 28px;
                font-weight: 800;
                color: #222;
                letter-spacing: -0.5px;
                margin-bottom: 4px;
            }

            .profile-role {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                font-size: 14px;
                font-weight: 600;
                color: #717171;
                padding: 4px 14px;
                background: #F7F7F7;
                border-radius: 20px;
                margin-top: 4px;
            }

            .profile-role.host {
                background: linear-gradient(135deg, #FFF0F3, #FFE4EA);
                color: #E31C5F;
            }

            .profile-role svg {
                width: 14px;
                height: 14px;
            }

            /* Stats Row */
            .profile-stats {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 0;
                padding: 20px 0;
                border-bottom: 1px solid #F0F0F0;
            }

            .stat-item {
                text-align: center;
                position: relative;
            }

            .stat-item:not(:last-child)::after {
                content: '';
                position: absolute;
                right: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 1px;
                height: 36px;
                background: #EBEBEB;
            }

            .stat-value {
                font-size: 22px;
                font-weight: 800;
                color: #222;
                line-height: 1.2;
            }

            .stat-label {
                font-size: 11px;
                font-weight: 500;
                color: #717171;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-top: 2px;
            }

            /* Verified Section */
            .verified-section {
                padding: 20px 0;
            }

            .verified-title {
                font-size: 14px;
                font-weight: 700;
                color: #222;
                margin-bottom: 14px;
                display: flex;
                align-items: center;
                gap: 6px;
            }

            .verified-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 8px 0;
            }

            .verified-icon {
                width: 36px;
                height: 36px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

            .verified-icon.email {
                background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
            }

            .verified-icon.identity {
                background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
            }

            .verified-icon.phone {
                background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
            }

            .verified-icon svg {
                width: 18px;
                height: 18px;
            }

            .verified-text {
                font-size: 14px;
                font-weight: 500;
                color: #222;
            }

            .verified-check {
                margin-left: auto;
                color: #00A699;
            }

            .verified-check svg {
                width: 18px;
                height: 18px;
            }

            /* ===== RIGHT CONTENT ===== */
            .profile-content {
                min-width: 0;
            }

            /* About Section */
            .section-block {
                margin-bottom: 36px;
            }

            .section-title {
                font-size: 24px;
                font-weight: 800;
                color: #222;
                letter-spacing: -0.3px;
                margin-bottom: 16px;
            }

            .about-card {
                background: #fff;
                border-radius: 20px;
                border: 1px solid #EBEBEB;
                padding: 28px;
                box-shadow: 0 1px 8px rgba(0, 0, 0, 0.03);
                transition: box-shadow 0.3s ease;
            }

            .about-card:hover {
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            }

            .about-details {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
            }

            .about-detail-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 14px 16px;
                background: #FAFAFA;
                border-radius: 14px;
                transition: all 0.2s ease;
            }

            .about-detail-item:hover {
                background: #F0F0F0;
                transform: translateX(4px);
            }

            .about-detail-icon {
                width: 40px;
                height: 40px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

            .about-detail-icon.location {
                background: linear-gradient(135deg, #FCE4EC, #F8BBD0);
            }

            .about-detail-icon.member {
                background: linear-gradient(135deg, #E8EAF6, #C5CAE9);
            }

            .about-detail-icon.type {
                background: linear-gradient(135deg, #FFF8E1, #FFECB3);
            }

            .about-detail-icon.email-d {
                background: linear-gradient(135deg, #E0F7FA, #B2EBF2);
            }

            .about-detail-icon svg {
                width: 20px;
                height: 20px;
            }

            .about-detail-text {
                display: flex;
                flex-direction: column;
                gap: 1px;
            }

            .about-detail-label {
                font-size: 11px;
                font-weight: 500;
                color: #717171;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .about-detail-value {
                font-size: 15px;
                font-weight: 600;
                color: #222;
            }

            /* ===== LISTINGS SECTION ===== */
            .listings-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
                gap: 24px;
            }

            .listing-card {
                background: #fff;
                border-radius: 18px;
                border: 1px solid #EBEBEB;
                overflow: hidden;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                cursor: pointer;
                box-shadow: 0 1px 6px rgba(0, 0, 0, 0.03);
            }

            .listing-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
                border-color: transparent;
            }

            .listing-card-img {
                width: 100%;
                height: 190px;
                object-fit: cover;
                transition: transform 0.4s ease;
            }

            .listing-card:hover .listing-card-img {
                transform: scale(1.06);
            }

            .listing-card-img-wrapper {
                overflow: hidden;
                position: relative;
            }

            .listing-card-price-tag {
                position: absolute;
                bottom: 12px;
                left: 12px;
                background: rgba(255, 255, 255, 0.95);
                backdrop-filter: blur(8px);
                padding: 6px 14px;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 700;
                color: #222;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            }

            .listing-card-price-tag span {
                font-weight: 400;
                color: #717171;
                font-size: 12px;
            }

            .listing-card-body {
                padding: 16px;
            }

            .listing-card-name {
                font-size: 16px;
                font-weight: 600;
                color: #222;
                margin-bottom: 4px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .listing-card-location {
                font-size: 13px;
                color: #717171;
                display: flex;
                align-items: center;
                gap: 4px;
                margin-bottom: 6px;
            }

            .listing-card-location svg {
                width: 14px;
                height: 14px;
                flex-shrink: 0;
            }

            .listing-card-meta {
                display: flex;
                align-items: center;
                gap: 12px;
                font-size: 12px;
                color: #717171;
            }

            .listing-card-meta span {
                display: flex;
                align-items: center;
                gap: 4px;
            }

            /* ===== EMPTY LISTINGS STATE ===== */
            .empty-listings {
                text-align: center;
                padding: 48px 24px;
                background: #fff;
                border-radius: 20px;
                border: 2px dashed #EBEBEB;
            }

            .empty-listings-icon {
                width: 80px;
                height: 80px;
                margin: 0 auto 16px;
                background: linear-gradient(135deg, #FFF0F3, #FFE4EA);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .empty-listings-icon svg {
                width: 36px;
                height: 36px;
                color: #FF385C;
            }

            .empty-listings h3 {
                font-size: 18px;
                font-weight: 700;
                color: #222;
                margin-bottom: 8px;
            }

            .empty-listings p {
                font-size: 14px;
                color: #717171;
                max-width: 320px;
                margin: 0 auto;
                line-height: 1.5;
            }

            /* ===== REVIEWS SECTION ===== */
            .reviews-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
            }

            .review-card {
                background: #fff;
                border-radius: 18px;
                border: 1px solid #EBEBEB;
                padding: 22px;
                transition: all 0.3s ease;
            }

            .review-card:hover {
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
                transform: translateY(-2px);
            }

            .review-stars {
                display: flex;
                gap: 2px;
                margin-bottom: 10px;
            }

            .review-stars svg {
                width: 14px;
                height: 14px;
                fill: #FF385C;
                color: #FF385C;
            }

            .review-text {
                font-size: 14px;
                color: #484848;
                line-height: 1.6;
                margin-bottom: 14px;
            }

            .review-author {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .review-author-avatar {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: linear-gradient(135deg, #667eea, #764ba2);
                display: flex;
                align-items: center;
                justify-content: center;
                color: #fff;
                font-size: 14px;
                font-weight: 700;
                flex-shrink: 0;
            }

            .review-author-name {
                font-size: 14px;
                font-weight: 600;
                color: #222;
            }

            .review-author-date {
                font-size: 12px;
                color: #717171;
            }

            /* ===== EDIT PROFILE BUTTON ===== */
            .edit-profile-btn {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 12px 24px;
                font-size: 14px;
                font-weight: 600;
                color: #222;
                background: #fff;
                border: 1.5px solid #222;
                border-radius: 12px;
                cursor: pointer;
                font-family: 'Inter', sans-serif;
                transition: all 0.2s ease;
                text-decoration: none;
                margin-top: 16px;
            }

            .edit-profile-btn:hover {
                background: #222;
                color: #fff;
            }

            .edit-profile-btn svg {
                width: 16px;
                height: 16px;
                transition: transform 0.2s ease;
            }

            .edit-profile-btn:hover svg {
                transform: rotate(15deg);
            }

            /* ===== RESPONSIVE ===== */
            @media (max-width: 900px) {
                .profile-grid {
                    grid-template-columns: 1fr;
                    gap: 24px;
                }

                .profile-card {
                    position: static;
                    max-width: 400px;
                    margin: 0 auto;
                    width: 100%;
                }

                .profile-page {
                    padding: 24px 16px 100px;
                }

                .about-details {
                    grid-template-columns: 1fr;
                }

                .reviews-grid {
                    grid-template-columns: 1fr;
                }

                .listings-grid {
                    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
                    gap: 16px;
                }
            }

            @media (max-width: 480px) {
                .profile-name {
                    font-size: 24px;
                }

                .section-title {
                    font-size: 20px;
                }

                .avatar-wrapper {
                    width: 100px;
                    height: 100px;
                }

                .avatar-img {
                    width: 100px;
                    height: 100px;
                }

                .profile-stats {
                    gap: 0;
                }

                .stat-value {
                    font-size: 18px;
                }
            }

            /* ===== DECORATIVE DOT PATTERN ===== */
            .dot-pattern {
                position: absolute;
                width: 80px;
                height: 80px;
                opacity: 0.04;
                background-image: radial-gradient(circle, #222 1px, transparent 1px);
                background-size: 8px 8px;
            }
        </style>
</head>

<body>

    <%- include("../partials/nav-bar") %>

        <main class="profile-page">

            <div class="profile-grid">

                <!-- ====== LEFT: PROFILE CARD ====== -->
                <aside class="anim-scale-in" style="animation-delay: 0.1s">
                    <div class="profile-card">

                        <!-- Top: Avatar + Name -->
                        <div class="profile-card-top">
                            <div class="avatar-wrapper">
                                <img src="<%= user.profilePic %>" alt="<%= user.firstName %>" class="avatar-img"
                                    onerror="this.src='https://res.cloudinary.com/dcrsi07me/image/upload/v1772456092/avatar_ft4hwd.png'">
                                <% if (user.userType==='host' ) { %>
                                    <div class="superhost-badge" title="Host">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <polygon
                                                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                                        </svg>
                                    </div>
                                    <% } %>
                            </div>

                            <h1 class="profile-name">
                                <%= user.firstName %>
                                    <%= user.lastName || '' %>
                            </h1>

                            <% if (user.userType==='host' ) { %>
                                <span class="profile-role host">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                        <polyline points="9 22 9 12 15 12 15 22" />
                                    </svg>
                                    Host
                                </span>
                                <% } else { %>
                                    <span class="profile-role">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="10" />
                                            <path d="M2 12h20" />
                                            <path
                                                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                                        </svg>
                                        Guest
                                    </span>
                                    <% } %>
                        </div>

                        <!-- Stats -->
                        <div class="profile-stats">
                            <div class="stat-item">
                                <div class="stat-value">
                                    <%= listings.length %>
                                </div>
                                <div class="stat-label">Listings</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value">
                                    <%= favouritesCount %>
                                </div>
                                <div class="stat-label">Saved</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value">5.0</div>
                                <div class="stat-label">Rating</div>
                            </div>
                        </div>

                        <!-- Verified Info -->
                        <div class="verified-section">
                            <div class="verified-title">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                    stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                </svg>
                                <%= user.firstName %>'s confirmed information
                            </div>

                            <div class="verified-item">
                                <div class="verified-icon email">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round">
                                        <path
                                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                        <polyline points="22,6 12,13 2,6" />
                                    </svg>
                                </div>
                                <span class="verified-text">Email address</span>
                                <span class="verified-check">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#00A699" stroke-width="2.5"
                                        stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                </span>
                            </div>

                            <div class="verified-item">
                                <div class="verified-icon identity">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                        <circle cx="12" cy="7" r="4" />
                                    </svg>
                                </div>
                                <span class="verified-text">Identity</span>
                                <span class="verified-check">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#00A699" stroke-width="2.5"
                                        stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                </span>
                            </div>

                            <div class="verified-item">
                                <div class="verified-icon phone">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#E65100" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                                        <line x1="12" y1="18" x2="12.01" y2="18" />
                                    </svg>
                                </div>
                                <span class="verified-text">Phone number</span>
                                <span class="verified-check">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="#00A699" stroke-width="2.5"
                                        stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                </span>
                            </div>
                        </div>

                        <% if (typeof userId !=='undefined' && userId && userId.toString()===user._id.toString()) { %>
                            <button class="edit-profile-btn"
                                onclick="window.location.href='/profile/<%= user._id %>/edit'">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                    stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                </svg>
                                Edit profile
                            </button>
                            <% } %>

                    </div>
                </aside>

                <!-- ====== RIGHT: CONTENT ====== -->
                <div class="profile-content">

                    <!-- About Section -->
                    <div class="section-block anim-fade-up" style="animation-delay: 0.2s">
                        <h2 class="section-title">About <%= user.firstName %>
                        </h2>
                        <div class="about-card">
                            <div class="about-details">

                                <div class="about-detail-item">
                                    <div class="about-detail-icon member">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="#3949AB" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                            <line x1="16" y1="2" x2="16" y2="6" />
                                            <line x1="8" y1="2" x2="8" y2="6" />
                                            <line x1="3" y1="10" x2="21" y2="10" />
                                        </svg>
                                    </div>
                                    <div class="about-detail-text">
                                        <span class="about-detail-label">Member since</span>
                                        <span class="about-detail-value">
                                            <%= memberSince.toLocaleDateString('en-US', { month: 'long' ,
                                                year: 'numeric' }) %>
                                        </span>
                                    </div>
                                </div>

                                <div class="about-detail-item">
                                    <div class="about-detail-icon type">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="#F57F17" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <polygon
                                                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                                        </svg>
                                    </div>
                                    <div class="about-detail-text">
                                        <span class="about-detail-label">Account type</span>
                                        <span class="about-detail-value" style="text-transform:capitalize">
                                            <%= user.userType %>
                                        </span>
                                    </div>
                                </div>

                                <div class="about-detail-item">
                                    <div class="about-detail-icon email-d">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="#00838F" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <path
                                                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                            <polyline points="22,6 12,13 2,6" />
                                        </svg>
                                    </div>
                                    <div class="about-detail-text">
                                        <span class="about-detail-label">Email</span>
                                        <span class="about-detail-value">
                                            <%= user.email %>
                                        </span>
                                    </div>
                                </div>

                                <div class="about-detail-item">
                                    <div class="about-detail-icon location">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="#C62828" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                            <circle cx="12" cy="10" r="3" />
                                        </svg>
                                    </div>
                                    <div class="about-detail-text">
                                        <span class="about-detail-label">Lives in</span>
                                        <span class="about-detail-value">India</span>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <!-- Listings Section -->
                    <div class="section-block anim-fade-up" style="animation-delay: 0.35s">
                        <h2 class="section-title">
                            <%= user.firstName %>'s listings
                                <% if (listings.length> 0) { %>
                                    <span style="font-size:16px; font-weight:500; color:#717171; margin-left:8px">(<%=
                                            listings.length %>)</span>
                                    <% } %>
                        </h2>

                        <% if (listings.length> 0) { %>
                            <div class="listings-grid">
                                <% listings.forEach((home, index)=> { %>
                                    <a href="/homes/<%= home._id %>" class="listing-card anim-fade-up"
                                        style="text-decoration:none; animation-delay: <%= (0.4 + index * 0.08).toFixed(2) %>s">
                                        <div class="listing-card-img-wrapper">
                                            <img src="<%= home.homeImages[0] %>" alt="<%= home.houseName %>"
                                                class="listing-card-img" loading="lazy">
                                            <div class="listing-card-price-tag">
                                                ₹<%= home.price.toLocaleString() %> <span>/ night</span>
                                            </div>
                                        </div>
                                        <div class="listing-card-body">
                                            <div class="listing-card-name">
                                                <%= home.houseName %>
                                            </div>
                                            <div class="listing-card-location">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                                    <circle cx="12" cy="10" r="3" />
                                                </svg>
                                                <%= home.location %>
                                            </div>
                                            <div class="listing-card-meta">
                                                <span>
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                        style="width:14px;height:14px">
                                                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                                        <polyline points="9 22 9 12 15 12 15 22" />
                                                    </svg>
                                                    <%= home.size %>
                                                </span>
                                                <span>⭐ 5.0</span>
                                            </div>
                                        </div>
                                    </a>
                                    <% }) %>
                            </div>
                            <% } else { %>
                                <div class="empty-listings">
                                    <div class="empty-listings-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                            <polyline points="9 22 9 12 15 12 15 22" />
                                        </svg>
                                    </div>
                                    <h3>No listings yet</h3>
                                    <p>
                                        <%= user.firstName %> hasn't listed any properties yet. Check back later!
                                    </p>
                                </div>
                                <% } %>
                    </div>
        </div>

        </main>

        <!-- Footer -->
        <%- include("../partials/footer") %>

            <%- include("../partials/nav-script") %>

                <script>
                    // Intersection Observer for scroll-triggered animations
                    const observerOptions = {
                        threshold: 0.1,
                        rootMargin: '0px 0px -40px 0px'
                    };

                    const observer = new IntersectionObserver((entries) => {
                        entries.forEach(entry => {
                            if (entry.isIntersecting) {
                                entry.target.style.animationPlayState = 'running';
                                observer.unobserve(entry.target);
                            }
                        });
                    }, observerOptions);

                    // Pause animations until visible
                    document.querySelectorAll('.anim-fade-up, .anim-scale-in').forEach(el => {
                        observer.observe(el);
                    });
                </script>

</body>

</html>