<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../partials/favicon') %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title>Log in – Airbnb</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background: linear-gradient(135deg, #FFF5F7 0%, #FFF 40%, #FFF5F7 100%);
        }

        .page-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px 16px;
        }

        .login-card {
            width: 100%;
            max-width: 440px;
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 8px 40px rgba(0,0,0,0.08), 0 0 0 1px rgba(0,0,0,0.04);
            padding: 40px 36px 36px;
            position: relative;
            overflow: hidden;
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #FF385C, #E31C5F, #BD1E59);
        }

        .login-header {
            text-align: center;
            margin-bottom: 32px;
        }

        .login-header img {
            height: 42px;
            margin-bottom: 16px;
            filter: drop-shadow(0 2px 6px rgba(255,56,92,0.2));
        }

        .login-header h1 {
            font-size: 24px;
            font-weight: 700;
            color: #222;
            margin-bottom: 6px;
        }

        .login-header p {
            font-size: 14px;
            color: #717171;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 24px 0;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #DDDDDD;
        }

        .divider span {
            font-size: 12px;
            color: #717171;
            font-weight: 500;
        }

        .form-group {
            margin-bottom: 16px;
            position: relative;
        }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #222;
            margin-bottom: 6px;
            letter-spacing: 0.2px;
        }

        .form-group input {
            width: 100%;
            padding: 14px 16px;
            border: 1.5px solid #DDDDDD;
            border-radius: 12px;
            font-size: 15px;
            font-family: 'Inter', sans-serif;
            color: #222;
            background: #fff;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-group input::placeholder {
            color: #B0B0B0;
        }

        .form-group input:focus {
            border-color: #222;
            box-shadow: 0 0 0 2px rgba(34,34,34,0.1);
        }

        .login-btn {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            color: #fff;
            background: linear-gradient(135deg, #FF385C, #E31C5F);
            cursor: pointer;
            transition: all 0.25s ease;
            margin-top: 8px;
            letter-spacing: 0.2px;
        }

        .login-btn:hover {
            background: linear-gradient(135deg, #E31C5F, #BD1E59);
            box-shadow: 0 6px 20px rgba(255,56,92,0.35);
            transform: translateY(-1px);
        }

        .login-btn:active {
            transform: translateY(0);
            box-shadow: 0 2px 8px rgba(255,56,92,0.3);
        }

        .social-login {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .social-btn {
            width: 100%;
            padding: 13px;
            border: 1.5px solid #DDDDDD;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            font-family: 'Inter', sans-serif;
            color: #222;
            background: #fff;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .social-btn:hover {
            background: #F7F7F7;
            border-color: #222;
        }

        .social-btn svg {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
        }

        .login-footer {
            text-align: center;
            margin-top: 24px;
            font-size: 14px;
            color: #717171;
        }

        .login-footer a {
            color: #FF385C;
            text-decoration: none;
            font-weight: 600;
        }

        .login-footer a:hover {
            text-decoration: underline;
        }

        /* ── Login Error Banner ── */
        .login-error-banner {
            background: linear-gradient(135deg, #FFF5F7 0%, #FFF0F3 100%);
            border: 1px solid rgba(255, 56, 92, 0.2);
            border-radius: 12px;
            padding: 14px 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            animation: bannerSlideDown 0.35s ease-out;
        }

        @keyframes bannerSlideDown {
            from { opacity: 0; transform: translateY(-8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-error-banner svg {
            flex-shrink: 0;
            width: 20px;
            height: 20px;
            margin-top: 1px;
        }

        .login-error-banner-content {
            flex: 1;
        }

        .login-error-banner-content strong {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #C13515;
            margin-bottom: 2px;
        }

        .login-error-banner-content span {
            font-size: 13px;
            color: #6B2D13;
            line-height: 1.5;
        }

        .login-error-banner-content a {
            color: #FF385C;
            font-weight: 600;
            text-decoration: none;
        }

        .login-error-banner-content a:hover {
            text-decoration: underline;
        }

        .login-error-dismiss {
            background: none;
            border: none;
            color: #C13515;
            cursor: pointer;
            font-size: 18px;
            line-height: 1;
            padding: 0;
            opacity: 0.6;
            transition: opacity 0.15s;
        }

        .login-error-dismiss:hover {
            opacity: 1;
        }

        @media (max-width: 480px) {
            .login-card {
                margin: 16px;
                padding: 32px 24px 28px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/nav-bar') %>
    <div class="page-content">
    <div class="login-card">
        <div class="login-card-top-bar"></div>

        <!-- Header -->
        <div class="login-header">
            <img src="/airbnb.png" alt="Airbnb">
            <h1>Welcome to Airbnb</h1>
            <p>Log in to continue your journey</p>
        </div>

        <% if(check && notexist || wrongPass){ %>
        <div class="login-error-banner" id="loginErrorBanner">
            <svg viewBox="0 0 20 20" fill="#FF385C">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
            <div class="login-error-banner-content">
                <strong><%= wrongPass? 'Incorrect password. Please try again' : 'Account not found' %></strong>
                <% if(notexist){ %>
                    <span>We couldn't find an account with that email. Please check your credentials or <a href="/signup">create a new account</a>.</span>
                <% } %>
            </div>
            <button type="button" class="login-error-dismiss" onclick="document.getElementById('loginErrorBanner').style.display='none'">&times;</button>
        </div>
        <% } %>

        <!-- Social Login -->
        <div class="social-login">
            <button type="button" class="social-btn">
                <svg viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                Continue with Google
            </button>
            <button type="button" class="social-btn">
                <svg viewBox="0 0 24 24" fill="#000"><path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.32 2.32-1.55 4.2-3.74 4.25z"/></svg>
                Continue with Apple
            </button>
        </div>

        <div class="divider"><span>or</span></div>

        <!-- Email/Password Form -->
        <form method="POST" action="/login">
            <div class="form-group">
                <label>Email</label>
                <input type="text" name="email" placeholder="you@example.com" value="<%= notexist || wrongPass? oldValues.email : '' %>" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="login-btn">Log in</button>
        </form>

        <!-- Footer -->
        <div class="login-footer">
            Don't have an account? <a href="/signup">Sign up</a>
        </div>
    </div>

    </div>
</body>
</html>