<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/favicon') %>
  <title>Wishlists – Airbnb</title>
  <link rel="stylesheet" href="/output.css">
  <style>
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .fade-up {
      opacity: 0;
      animation: fadeUp 0.5s ease-out forwards;
    }

    .header-fade {
      animation: fadeUp 0.4s ease-out forwards;
      opacity: 0;
    }
  </style>
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

  <%- include("../partials/nav-bar") %>

    <!-- Page Header -->
    <div class="max-w-7xl mx-auto w-full px-6 pt-8 pb-2 header-fade">
      <h1 class="text-3xl font-bold text-gray-900">Wishlists</h1>
      <p class="text-gray-500 mt-1">
        <% if(fav && fav.length> 0) { %>
          <%= fav.length %> place<%= fav.length> 1 ? 's' : '' %> saved
              <% } else { %>
                Places you saved for later
                <% } %>
      </p>
    </div>

    <% if(fav && fav.length> 0) { %>

      <!-- Cards Grid -->
      <div class="max-w-7xl mx-auto w-full px-6 py-6 flex-1">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

          <% fav.forEach((home, index)=> { %>

            <!-- Wishlist Card -->
            <div class="fade-up bg-white rounded-2xl overflow-hidden 
                    shadow-md hover:shadow-2xl 
                    transition duration-300 transform hover:-translate-y-2 
                    border border-gray-200 cursor-pointer group"
              style="animation-delay: <%- (index * 0.08 + 0.1).toFixed(2) %>s">

              <!-- Image -->
              <a href="/homes/<%= home._id %>">
                <div class="h-56 overflow-hidden relative">
                  <img src="<%= home.homeImages[0] %>" alt="<%= home.houseName %>" loading="lazy"
                    class="w-full h-full object-cover transition duration-300 group-hover:scale-110" />

                  <!-- Saved Heart (filled) -->
                  <%- include("../partials/save-btn",{home:home}) %>
                </div>

                <!-- Content -->
                <div class="p-4">

                  <div class="flex justify-between items-center">
                    <h3 class="text-gray-800 font-semibold text-md truncate">
                      <%= home.houseName %>
                    </h3>
                    <span class="text-sm flex items-center gap-1">⭐ 5.0</span>
                  </div>

                  <p class="text-gray-500 text-sm mt-1">
                    <%= home.location %>
                  </p>

                  <p class="text-gray-400 text-sm mt-1 line-clamp-2">
                    <%= home.homeDescription %>
                  </p>

                  <p class="mt-2 text-gray-900 font-semibold">
                    ₹<%= home.price %>
                      <span class="text-gray-500 font-normal">/ night</span>
                  </p>

              </a>

              <!-- Book Now Button -->
              <div class="mt-3">
                <a href="/homes/<%= home.id %>">
                  <button
                    class="w-full rounded-lg bg-[#FF5A5F] px-4 py-2 text-sm font-medium text-white shadow-md transition hover:bg-[#e04848] hover:shadow-lg active:scale-95">
                    Book Now
                  </button>
                </a>
              </div>

            </div>

        </div>

        <% }) %>

      </div>
      </div>

      <% } else { %>

        <!-- Empty State -->
        <div class="flex-1 flex items-center justify-center px-6">
          <div class="text-center py-20 max-w-md fade-up" style="animation-delay: 0.15s">

            <div class="w-40 h-40 mx-auto mb-8 relative">
              <div class="absolute inset-0 bg-gradient-to-br from-[#FF5A5F]/10 to-[#FC642D]/5 rounded-full"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <svg class="w-20 h-20 text-[#FF5A5F]/50" fill="none" stroke="currentColor" stroke-width="1.2"
                  viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              </div>
            </div>

            <h2 class="text-2xl font-bold text-gray-900 mb-2">No wishlists yet</h2>
            <p class="text-gray-500 leading-relaxed mb-8">
              As you search, tap the heart icon to save your favourite places to stay.
            </p>

            <a href="/" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl
                bg-gradient-to-r from-[#FF5A5F] to-[#FC642D] text-white font-semibold
                shadow-lg shadow-red-200 hover:shadow-xl hover:shadow-red-300
                hover:from-[#e04848] hover:to-[#e55a28] transition-all duration-200 active:scale-95">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              Start exploring
            </a>

          </div>
        </div>

        <% } %>

          <!-- Footer -->
          <%- include("../partials/footer") %>

          <%- include("../partials/wishlist-toast") %>

            <script>
              function saveToWishlist(btn) {
                const id = btn.dataset.id;
                let isFav = btn.dataset.fav === "true";

                const svg = btn.querySelector('svg');

                // toggle state
                isFav = !isFav;
                btn.dataset.fav = isFav;

                // 🔥 click animation (button)
                btn.classList.add('scale-125');
                setTimeout(() => btn.classList.remove('scale-125'), 200);

                fetch('/wishlists', {
                  method: isFav ? 'POST' : 'DELETE',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ id })
                })
                  .then(res => res.json())
                  .then(data => {

                    if (!isFav) {
                      const card = btn.closest('.group');

                      // 🔥 smooth animation
                      card.style.transition = "all 0.4s ease";
                      card.style.opacity = "0";
                      card.style.transform = "scale(0.9) translateY(20px)";

                      // optional blur effect 😎
                      card.style.filter = "blur(4px)";

                      // remove after animation
                      setTimeout(() => {
                        card.remove();
                      }, 400);
                    }
                    if (typeof showToast === 'function') {
                      showToast(data.message || (isFav ? 'Saved ❤️' : 'Removed 🗑️'));
                    }
                  })
                  .catch(() => {
                    if (typeof showToast === 'function') {
                      showToast('Something went wrong');
                    }
                  });

                return false;
              }
            </script>

            <%- include("../partials/nav-script") %>

</body>

</html>